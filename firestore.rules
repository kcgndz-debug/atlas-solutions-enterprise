rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return userExists() &&
        currentUser().active == true &&
        currentUser().role == "owner";
    }

    function belongsTo(companyId) {
      return userExists() &&
        currentUser().active == true &&
        (currentUser().role == "owner" || companyId in currentUser().companyIds);
    }

    match /system/bootstrap {
      allow read: if signedIn();
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/system/bootstrap)
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/system/bootstrap)
        && request.resource.data.role == "owner";
      allow read: if signedIn() && (request.auth.uid == uid || isOwner());
      allow update: if signedIn() && (request.auth.uid == uid || isOwner());
      allow delete: if isOwner();
    }

    match /companies/{companyId} {
      allow create: if isOwner()
        || (signedIn() && !exists(/databases/$(database)/documents/system/bootstrap));
      allow read: if belongsTo(companyId);
      allow update, delete: if isOwner();
    }


    match /projects/{id} {
      allow create: if belongsTo(request.resource.data.companyId);
      allow read, update, delete: if belongsTo(resource.data.companyId);
    }

    match /counters/{id} {
      allow read, write: if isOwner();
    }

    match /customers/{id} {
      allow create: if belongsTo(request.resource.data.companyId);
      allow read, update, delete: if belongsTo(resource.data.companyId);
    }

    match /estimates/{id} {
      allow create: if belongsTo(request.resource.data.companyId);
      allow read, update, delete: if belongsTo(resource.data.companyId);
    }
  }
}
